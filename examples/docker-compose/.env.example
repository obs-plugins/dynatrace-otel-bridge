# ── Dynatrace OTLP ingest ─────────────────────────────────────────────
# Endpoint OTLP/HTTP do teu tenant Dynatrace.
# SaaS:    https://<env-id>.live.dynatrace.com/api/v2/otlp
# Managed: https://<managed-host>/e/<env-id>/api/v2/otlp
DT_OTLP_ENDPOINT=https://<env-id>.live.dynatrace.com/api/v2/otlp

# API Token Dynatrace com scopes de INGEST (NÃO os de leitura do plugin):
#   metrics.ingest, logs.ingest, openTelemetryTrace.ingest
# Formato: prefixo dt0c01. + public id + secret
DT_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# ── Opcional ──────────────────────────────────────────────────────────
# Valor do resource attribute deployment.environment (processor "resource").
# Ex.: dev | staging | production
DEPLOYMENT_ENVIRONMENT=development
